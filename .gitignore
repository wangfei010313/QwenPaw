# 1. Python 虚拟环境与缓存 (绝对不能传，否则仓库会大几个GB！)
qp_env/
venv/
env/
.venv/
__pycache__/
*.py[cod]
*.class
# 2. 临时文件与备份 (刚才脚本生成的 .bak 等)
*.bak
*.log
*.tmp
# 3. 敏感信息 (防止 API Key 泄露)
.env
.env.*
*.key
*.pem
# 4. IDE 与操作系统生成的隐藏文件
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini
# 5. QwenPaw 本地运行时数据 (如果项目内有的话)
.qwenpaw/
memory/
*.sqlite3
# 6. 补充 Python 打包和构建产生的垃圾文件
build/
dist/
*.egg-info/
*.egg
